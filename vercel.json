{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/[...route].js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/app.js",
      "destination": "/public/app.js"
    },
    {
      "source": "/styles.css",
      "destination": "/public/styles.css"
    },
    {
      "source": "/(.*)",
      "destination": "/public/index.html"
    }
  ]
}
